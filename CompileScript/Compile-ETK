#!/bin/bash

#echo "Compile-ETK (c) 2024 Liwei Ji"

# ----------------
# Global Functions
# ----------------

# Execute and print the command; abort on failure so a broken step
# (e.g. a failed reconfigure) never cascades into the next one
execute_command() {
    echo "\$ $@"
    "$@" || { local status=$?; echo "Error: command failed with status $status: $@" >&2; exit $status; }
}
export -f execute_command

# ---------------
# Local Functions
# ---------------

# Help message
display_usage() {
    echo "Usage: $0 [options]"
    echo
    echo "Options:"
    echo "  -h, --help       Show this help message and exit"
    echo "  --fresh          Perform a fresh compilation"
    echo "  -e <executable>  Specify the executable name (default: $executable_name)"
    echo "  -t <thorn_list>  Specify the thorn list file (default: $thorn_list)"
    echo "  -c <config_file> Specify the configuration file (required with --fresh)"
    echo "  -j <num_cores>   Specify the number of cores for parallel build (default: $num_cores)"
    echo
    echo "Arguments are optional unless noted; unspecified ones use default values."
}

# Handle argument parsing
process_arguments() {
    local args=()

    # Preprocess long options
    for arg in "$@"; do
        case "$arg" in
            --fresh)
                perform_fresh_compile=true ;;
            --help)
                display_usage; exit 0 ;;
            *)
                args+=("$arg") ;;
        esac
    done

    # Reset positional arguments for `getopts`
    set -- "${args[@]}"

    # Parse short options
    while getopts ":e:t:c:j:h" opt; do
        case "$opt" in
            e) executable_name="$OPTARG" ;;
            t) thorn_list="$OPTARG" ;;
            c) config_file="$OPTARG" ;;
            j) num_cores="$OPTARG" ;;
            h) display_usage; exit 0 ;;
            :) echo "Error: Option -$OPTARG requires an argument." >&2; display_usage; exit 1 ;;
            \?) echo "Error: Invalid option -$OPTARG" >&2; display_usage; exit 1 ;;
        esac
    done
}

# -------------
# Main Function
# -------------

main() {
    # Default values
    executable_name="etk"
    thorn_list="thornlists/asterx.th"
    config_file=""
    perform_fresh_compile=false
    num_cores=24

    # Process arguments
    process_arguments "$@"

    config_path="configs/$executable_name"

    # Sanity checks before touching the build tree
    if [[ ! -f "$thorn_list" ]]; then
        echo "Error: Thorn list '$thorn_list' not found." >&2
        exit 1
    fi

    if [[ $perform_fresh_compile == true ]]; then
        if [[ -z "$config_file" ]]; then
            echo "Error: --fresh requires a configuration file (-c <config_file>)." >&2
            display_usage
            exit 1
        fi
        if [[ ! -f "$config_file" ]]; then
            echo "Error: Configuration file '$config_file' not found." >&2
            exit 1
        fi
    elif [[ ! -d "$config_path" ]]; then
        # Without this guard, gmake would silently create a new configuration
        # from the bare environment (no option list), leaving a broken config
        echo "Error: Configuration '$executable_name' does not exist yet." >&2
        echo "Run with --fresh -c <config_file> to create it first." >&2
        exit 1
    fi

    # Main script logic
    if [[ $perform_fresh_compile == true ]]; then
        echo "Performing a fresh compile for '$executable_name' with $config_file using $num_cores cores..."

        # Remove existing config directory
        if [[ -d "$config_path" ]]; then
            echo "Removing existing directory: $config_path"
            execute_command rm -rf "$config_path"
        fi

        # Fresh compile steps
        # PROMPT=no: skip Cactus' interactive "Setup configuration (yes)?"
        # confirmation, which auto-cancels when stdin is not a terminal
        execute_command gmake "$executable_name" options="$config_file" PROMPT=no
    fi

    # Compilation with specified cores
    execute_command cp "$thorn_list" "configs/$executable_name/ThornList"
    execute_command gmake -j"$num_cores" "$executable_name" PROMPT=no
}

# Entry point
main "$@"
